{
    "dataset_type": "amr_parsing",
    "data_path": "viamr-project/amr-translated",
    "src_column": "vi",
    "tgt_column": "amr",
    "remove_wiki": true,
    "dedupe": false,
    "fix_ftfy": false,
    "normalize_punct": false,
    "detokenize": false,
    "remove_bracketed": false,
    "dereify": false,
    "max_length": 512,
    "packing": false,
    "batch_by_tokens": false,
    "num_diffusion_timesteps": 50,
    "diffusion_type": "absorbing",
    "pretrained": "FacebookAI/xlm-roberta-large",
    "cache_dir": "cache",
    "attention_strategy": "full",
    "vocab_pad_to_multiple": 1,
    "lora": false,
    "output_dir": "outputs/amr_parsing",
    "per_device_train_batch_size": 8,
    "per_device_eval_batch_size": 8,
    "gradient_accumulation_steps": 8,
    "max_steps": 30000,
    "do_eval": true,
    "eval_strategy": "steps",
    "eval_steps": 1500,
    "eval_metric": "smatchpp",
    "load_best_model_at_end": true,
    "metric_for_best_model": "smatchpp",
    "greater_is_better": true,
    "logging_steps": 10,
    "save_steps": 1500,
    "save_total_limit": 3,
    "report_to": "wandb",
    "wandb_project": "mlm-to-dlm",
    "run_name": "amr_parsing_roberta",
    "log_level": "info",
    "remove_unused_columns": false,
    "learning_rate": 5e-5,
    "weight_decay": 0.01,
    "adam_beta1": 0.9,
    "adam_beta2": 0.98,
    "lr_scheduler": "cosine",
    "warmup_ratio": 0.01,
    "bf16": true,
    "bf16_full_eval": true,
    "label_smoothing_factor": 0,
    "mask_ratio_sampler": "diffusion",
    "train_length": false,
    "weighting": "linear",
    "mask_on_source": false,
    "mask_on_paddings": false,
    "max_iterations": 50,
    "mbr": 1,
    "length_beam": 1,
    "oracle_length": true,
    "strategy": "reparam-uncond-deterministic-cosine",
    "argmax_decoding": true,
    "bpe": "sentencepiece",
    "bleu_tokenize": "13a",
    "return_history": false,
    "temperature": 1.0,
    "save_safetensors": false
}
