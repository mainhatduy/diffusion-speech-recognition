{
    "dataset_type": "speech_translation_multitask",
    "data_path": "NhutP/VietSpeech",
    "audio_encoder_name": "UsefulSensors/moonshine-streaming-medium",
    "task_tokens": [
        "<vi_en>",
        "<vi_zh>",
        "<vi_ko>"
    ],
    "max_length": 128,
    "packing": false,
    "precomputed_data_dir": "precomputed_data_1",
    "batch_by_tokens": false,
    "num_diffusion_timesteps": 50,
    "diffusion_type": "absorbing",
    "pretrained": "FacebookAI/xlm-roberta-base",
    "cache_dir": "cache",
    "attention_strategy": "full",
    "vocab_pad_to_multiple": 1,
    "lora": false,
    "output_dir": "outputs/test_vi_multitask",
    "per_device_train_batch_size": 4,
    "per_device_eval_batch_size": 2,
    "dataloader_num_workers": 2,
    "dataloader_pin_memory": true,
    "gradient_accumulation_steps": 1,
    "max_steps": 10,
    "do_eval": true,
    "eval_strategy": "steps",
    "eval_steps": 5,
    "eval_metric": "wer",
    "eval_metrics": [
        "bleu",
        "wer"
      ],
    "load_best_model_at_end": true,
    "metric_for_best_model": "wer",
    "greater_is_better": true,
    "logging_steps": 1,
    "save_steps": 5,
    "save_total_limit": 1,
    "report_to": "none",
    "run_name": "test_vi_multitask",
    "log_level": "info",
    "remove_unused_columns": false,
    "learning_rate": 1e-4,
    "weight_decay": 0.01,
    "adam_beta1": 0.9,
    "adam_beta2": 0.98,
    "lr_scheduler_type": "cosine",
    "warmup_steps": 0.1,
    "bf16": true,
    "bf16_full_eval": true,
    "label_smoothing_factor": 0,
    "mask_ratio_sampler": "diffusion",
    "train_length": false,
    "weighting": "linear",
    "mask_on_source": false,
    "mask_on_paddings": false,
    "max_iterations": 10,
    "mbr": 1,
    "length_beam": 1,
    "oracle_length": true,
    "strategy": "reparam-uncond-deterministic-cosine",
    "argmax_decoding": true,
    "bpe": "sentencepiece",
    "bleu_tokenize": "13a",
    "return_history": false,
    "temperature": 1.0
}
