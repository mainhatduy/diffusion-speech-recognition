{
    "dataset_type": "speech_translation_multitask",
    "data_path": "NhutP/VietSpeech",
    "audio_encoder_name": "UsefulSensors/moonshine-streaming-medium",
    "audio_fusion_strategy": "deep_cross_attn",
    "task_tokens": [
        "<vi_en>"
    ],
    "max_length": 128,
    "packing": false,
    "precomputed_data_dir": "precomputed_data",
    "batch_by_tokens": false,
    "num_diffusion_timesteps": 50,
    "diffusion_type": "absorbing",
    "pretrained": "FacebookAI/xlm-roberta-base",
    "cache_dir": "cache",
    "attention_strategy": "full",
    "vocab_pad_to_multiple": 1,
    "lora": false,
    "output_dir": "outputs/vi_en_deep_fusion",
    "per_device_train_batch_size": 64,
    "per_device_eval_batch_size": 16,
    "dataloader_num_workers": 16,
    "dataloader_pin_memory": true,
    "dataloader_prefetch_factor": 8,
    "gradient_accumulation_steps": 2,
    "max_steps": 100000,
    "do_eval": true,
    "eval_strategy": "steps",
    "eval_steps": 5000,
    "eval_metric": "wer",
    "eval_metrics": [
        "bleu",
        "wer"
    ],
    "load_best_model_at_end": true,
    "metric_for_best_model": "wer",
    "greater_is_better": false,
    "logging_steps": 200,
    "save_steps": 5000,
    "save_total_limit": 3,
    "report_to": "wandb",
    "wandb_project": "diffusion-speech-recognition",
    "run_name": "vi_en_deep_fusion",
    "log_level": "info",
    "remove_unused_columns": false,
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "adam_beta1": 0.9,
    "adam_beta2": 0.98,
    "lr_scheduler_type": "cosine",
    "warmup_steps": 0.1,
    "bf16": true,
    "bf16_full_eval": true,
    "label_smoothing_factor": 0,
    "mask_ratio_sampler": "diffusion",
    "train_length": false,
    "weighting": "linear",
    "mask_on_source": false,
    "mask_on_paddings": false,
    "max_iterations": 10,
    "mbr": 1,
    "length_beam": 1,
    "oracle_length": true,
    "strategy": "reparam-uncond-deterministic-cosine",
    "argmax_decoding": true,
    "bpe": "sentencepiece",
    "bleu_tokenize": "13a",
    "return_history": false,
    "temperature": 1.0,
    "push_to_hub": true,
    "hub_model_id": "aiai-laboratory/discrete-diffusion-vi-en-deep-fusion"
}
